{
  "name": "chokepidgin",
  "version": "1.0.0",
  "description": "ChokePidgin.com - Learn Hawaiian Pidgin English",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "./scripts/dev-server.sh",
    "build": "node build.js",
    "build:quick": "node build.js --quick",
    "build:css": "npx @tailwindcss/cli -i src/styles/tailwind.css -o public/css/tailwind.css --minify",
    "watch:css": "npx @tailwindcss/cli -i src/styles/tailwind.css -o public/css/tailwind.css --watch",
    "deploy": "./scripts/deploy.sh",
    "data:add-missing": "node tools/data/add-missing-terms.js",
    "data:improve": "node tools/data/improve-dictionary.js",
    "data:crosswords": "node tools/data/generate-more-crosswords.js",
    "seo:loop": "node tools/seo/feedback-loop.js",
    "test": "node tools/testing/run-validation.js",
    "test:translator": "node tools/testing/validate-phase-2-3.js",
    "generate:sitemap": "node tools/generators/generate-sitemap.js",
    "generate:pages": "node tools/generators/generate-entry-pages.js",
    "generate:phrases": "node tools/generators/generate-phrase-pages.js",
    "generate:stories": "node tools/generators/generate-story-pages.js",
    "generate:pickups": "node tools/generators/generate-pickup-pages.js",
    "validate": "npm run test",
    "migrate:supabase": "node tools/migrate-to-supabase.js",
    "seo:queries": "node tools/seo/search-console.js queries",
    "seo:pages": "node tools/seo/search-console.js pages",
    "seo:optimize": "node tools/seo/search-console.js optimize",
    "seo:report": "node tools/seo/search-console.js report",
    "seo:api": "node tools/seo/search-console.js api-server",
    "ga:top-pages": "node tools/seo/google-analytics.js top-pages",
    "ga:traffic": "node tools/seo/google-analytics.js traffic",
    "ga:devices": "node tools/seo/google-analytics.js devices",
    "ga:engagement": "node tools/seo/google-analytics.js engagement",
    "ga:low-engagement": "node tools/seo/google-analytics.js low-engagement",
    "ga:events": "node tools/seo/google-analytics.js events",
    "ga:realtime": "node tools/seo/google-analytics.js realtime",
    "ga:report": "node tools/seo/google-analytics.js report",
    "ga:insights": "node tools/seo/google-analytics.js insights --format claude"
  },
  "keywords": [
    "pidgin",
    "hawaiian",
    "language",
    "learning",
    "translator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/translate": "^9.3.0",
    "@supabase/supabase-js": "^2.97.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@google-analytics/data": "^5.2.1",
    "@tailwindcss/cli": "^4.2.1",
    "google-auth-library": "^9.15.1",
    "sharp": "^0.34.5",
    "supabase": "^2.76.14",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.1"
  },
  "overrides": {
    "tar": "^7.5.8",
    "minimatch": ">=3.1.3",
    "qs": "^6.14.2",
    "http-proxy-agent": "^7.0.2"
  }
}
